<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Ignore Finalizer attacks on constructors (caused by Lombok @NonNull) -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW" />
    </Match>
    
    <!-- Ignore storing mutable objects for specific fields that shouldn't be cloned -->
    <Match>
        <Class name="dev.arpit.pm1.logger.core.LogPipeline" />
        <Field name="logWriter" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Class name="dev.arpit.pm1.logger.models.LogEvent$Builder" />
        <Field name="throwable" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
    <Match>
        <Class name="dev.arpit.pm1.logger.enrichers.CallerClassEnricher" />
        <Field name="excludedClasses" />
        <Bug pattern="EI_EXPOSE_REP2" />
    </Match>
</FindBugsFilter>
